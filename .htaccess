# Jaipur Home Care — project root
# Upload this file to the same folder as app/, public/, system/

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route requests into public/ (hide public from URL)
    RewriteRule ^$ public/ [L]
    RewriteRule ^((?!public/).*)$ public/$1 [L,NC]
</IfModule>
